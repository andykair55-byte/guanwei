# ========== 运行模式 ==========
# 开发模式开关（true/false）
# true 时允许使用 SQLite 和默认 SECRET_KEY，生产环境必须设置为 false
DEV_MODE=true

# ========== CORS 配置 ==========
# 允许的前端域名，逗号分隔
# 开发环境默认：http://localhost:5173,http://localhost:4173,http://localhost:3000
# 生产环境必须配置为真实域名
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ========== 数据库 ==========
# 数据库连接 URL
# 开发环境示例（SQLite）：sqlite:///./jianwei.db
# 生产环境示例（PostgreSQL）：postgresql://user:pass@localhost:5432/jianwei
DATABASE_URL=sqlite:///./jianwei.db

# Redis 连接 URL
# 示例：redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# JWT 密钥
# 生产环境必须设置为强随机字符串，开发环境可使用默认值
# 生成方式：openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

LLM_PROVIDER=deepseek

# ========== LLM 多资源矩阵（spec-11） ==========
# 健康检查间隔（秒），默认 300（5 分钟）
LLM_HEALTH_CHECK_INTERVAL=300
# 熔断器连续失败阈值，达到后熔断该 key
LLM_CIRCUIT_FAILURE_THRESHOLD=3
# 熔断器恢复超时（秒），OPEN 持续时间，过后进入 HALF_OPEN 探测
LLM_CIRCUIT_RECOVERY_TIMEOUT=60
# 每个 provider 的 *_API_KEY 均支持逗号分隔多 key，例如：key1,key2,key3
# 每个 *_API_KEY_RPM 表示该 provider 单个 key 每分钟最大请求数（0 或不填表示不限）
# 多 key 池化后总 rpm = *_API_KEY_RPM × key 数量

# ========== 国产模型 ==========
# DeepSeek
# 支持逗号分隔多 key，例如：key1,key2,key3
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_KEY_RPM=0
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM
# 支持逗号分隔多 key，例如：key1,key2,key3
GLM_API_KEY=your_glm_api_key
GLM_API_KEY_RPM=0
GLM_MODEL=glm-4-plus

# 通义千问
# 支持逗号分隔多 key，例如：key1,key2,key3
QWEN_API_KEY=your_qwen_api_key
QWEN_API_KEY_RPM=0
QWEN_MODEL=qwen-plus

# Kimi (月之暗面)
# 支持逗号分隔多 key，例如：key1,key2,key3
KIMI_API_KEY=your_kimi_api_key
KIMI_API_KEY_RPM=0
KIMI_MODEL=moonshot-v1-8k

# 豆包 (火山引擎)
# 支持逗号分隔多 key，例如：key1,key2,key3
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_KEY_RPM=0
DOUBAO_MODEL=doubao-pro-32k

# MiniMax
# 支持逗号分隔多 key，例如：key1,key2,key3
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_API_KEY_RPM=0
MINIMAX_MODEL=abab6.5s-chat

# 阶跃星辰
# 支持逗号分隔多 key，例如：key1,key2,key3
STEPFUN_API_KEY=your_stepfun_api_key
STEPFUN_API_KEY_RPM=0
STEPFUN_MODEL=step-1-8k

# ========== 国外模型 ==========
# OpenAI
# 支持逗号分隔多 key，例如：key1,key2,key3
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_KEY_RPM=0
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# 支持逗号分隔多 key，例如：key1,key2,key3
ANTHROPIC_API_KEY=your_claude_api_key
ANTHROPIC_API_KEY_RPM=0
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
# 支持逗号分隔多 key，例如：key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_RPM=0
GEMINI_MODEL=gemini-1.5-flash

# Groq
# 支持逗号分隔多 key，例如：key1,key2,key3
# 多个 rpm30 的 key 池化示例：GROQ_API_KEY=key1,key2,key3 + GROQ_API_KEY_RPM=30 → 总 rpm 90
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_RPM=0
GROQ_MODEL=llama-3.3-70b-versatile

# ========== 自定义模型 ==========
# 支持逗号分隔多 key，例如：key1,key2,key3
CUSTOM_API_KEY=your_custom_api_key
CUSTOM_API_KEY_RPM=0
CUSTOM_BASE_URL=https://your-custom-api.com/v1
CUSTOM_MODEL=your-model-name
