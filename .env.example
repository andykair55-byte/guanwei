# 见微项目环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# SQLite（MVP阶段）
# DATABASE_URL=sqlite:///./jianwei.db

# PostgreSQL（验证期）
DATABASE_URL=postgresql://jianwei:jianwei_dev_password@localhost:5432/jianwei

# ==================== Redis 缓存配置 ====================
REDIS_URL=redis://localhost:6379/0
# Redis 密码（生产环境必填）
# REDIS_PASSWORD=

# ==================== JWT 认证配置 ====================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ==================== LLM 模型配置 ====================
# 默认主模型提供商
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 GLM
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 通义千问
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Kimi（月之暗面）
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# 豆包（火山引擎）
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 阶跃星辰 StepFun
STEPFUN_API_KEY=your_stepfun_api_key
STEPFUN_BASE_URL=https://api.stepfun.com/v1

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1

# 自定义模型
# CUSTOM_API_KEY=your_custom_api_key
# CUSTOM_BASE_URL=https://your-custom-endpoint/v1
# CUSTOM_MODEL=your_model_name

# ==================== 前端配置 ====================
# API 基础地址（前端）
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ==================== 应用配置 ====================
# 应用名称
APP_NAME=见微
# 应用版本
APP_VERSION=1.0.0
# 调试模式
DEBUG=true

# ==================== 每日免费求证次数 ====================
FREE_VERIFY_COUNT=3